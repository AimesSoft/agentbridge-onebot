# Bridge HTTP server
QQBRIDGE_HOST=0.0.0.0
QQBRIDGE_PORT=8787
QQBRIDGE_WEBHOOK_PATH=/onebot
# Optional shared token for NapCat -> bridge. Send it as X-QQBridge-Token or Authorization: Bearer ...
QQBRIDGE_WEBHOOK_TOKEN=
# Required for Hermes qqbridge-skill -> bridge. Send it as X-QQBridge-Skill-Token or Authorization: Bearer ...
QQBRIDGE_SKILL_TOKEN=

# NapCat OneBot HTTP API
NAPCAT_BASE_URL=http://127.0.0.1:3000
NAPCAT_ACCESS_TOKEN=

# Hermes OpenAI-compatible API
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_SECONDS=120

# Bot identity and safety
BOT_QQ_ID=
BOT_NAMES=bridge,agent,bot
ADMIN_QQ_IDS=
ADMIN_PREFIX=。
PUBLIC_PREFIX=/
BOT_PERSONA=你说话自然、简洁、带一点机灵劲，但不油腻，不自称“作为AI”。

# Group autonomous chat defaults. Per-group values can be overridden in config.yaml or by admin commands.
GROUP_DEFAULT_AUTONOMOUS_ENABLED=false
GROUP_MIN_SECONDS_BETWEEN_REPLIES=90
AMBIENT_ENABLED=true
AMBIENT_INTERVAL_SECONDS=3600
AMBIENT_MIN_UNREAD_MESSAGES=1
AMBIENT_MAX_UNREAD_MESSAGES=120
AMBIENT_JITTER_MIN_SECONDS=300
AMBIENT_JITTER_MAX_SECONDS=10800
AGENT_RUN_TTL_SECONDS=900
SKILL_ONEBOT_LEVEL=group_admin

# Conversation and output controls
MAX_HISTORY_MESSAGES=16
MAX_GROUP_CONTEXT_MESSAGES=8
MAX_MESSAGE_CHARS=850
USER_RATE_LIMIT_PER_MINUTE=12
STATE_PATH=data/state.json
MESSAGE_STORE_PATH=data/messages.sqlite3
MESSAGE_ARCHIVE_DIR=data/message_archive
QQBRIDGE_CONFIG=config.yaml

# GitHub. Prefer a fine-grained PAT with Actions read/write for the target repo.
GITHUB_TOKEN=
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_DEFAULT_REF=main
GITHUB_RELEASE_WORKFLOW=release.yml
GITHUB_DEPLOY_WORKFLOW=deploy.yml
GITHUB_API_VERSION=2026-03-10
